# ── Model Configuration ────────────────────────────────────────────────────────
# Bi-encoder model for vector embeddings (Stage 1)
BIENCODER_MODEL=all-MiniLM-L6-v2

# Cross-encoder model for re-ranking (Stage 2)
CROSSENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── ChromaDB Configuration ─────────────────────────────────────────────────────
# Directory where ChromaDB persists the vector index
CHROMA_PERSIST_DIR=./data/chroma_db

# ── API Configuration ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Retrieval Configuration ────────────────────────────────────────────────────
# Default number of results to return
DEFAULT_K=10

# Candidate pool multiplier for re-ranking (candidates = k * multiplier)
CANDIDATE_MULTIPLIER=10

# ── Data Paths ─────────────────────────────────────────────────────────────────
CHUNKS_PATH=./data/processed/chunks.jsonl
RAW_DATA_DIR=./data/raw

# ── Hardware ───────────────────────────────────────────────────────────────────
# Set to 1 to force CPU even if GPU is available (0 = use GPU if available)
FORCE_CPU=0
